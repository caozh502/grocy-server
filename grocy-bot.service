[Unit]
Description=Grocy Telegram Bot
After=network.target docker.service
Requires=docker.service

[Service]
Type=simple
User=ubuntu
WorkingDirectory=/home/ubuntu/grocy-server
ExecStart=/usr/bin/python3 /home/ubuntu/grocy-server/grocy_bot.py
Restart=on-failure
RestartSec=10

[Install]
WantedBy=multi-user.target
