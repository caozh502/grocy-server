# Grocy Server Config
# 复制为 .env 并填入真实值，.env 已被 .gitignore 排除

# Telegram Bot（必填）
BOT_TOKEN=你的BotToken
GROUP_ID=你的群组ID

# Grocy API
API_KEY=你的GrocyAPIKey
API_URL=http://127.0.0.1:8080/api

# Grocy 数据库路径（默认即可）
DB_PATH=~/grocy-data/data/grocy.db

# DuckDNS 域名（Caddyfile 用）
DOMAIN=your-domain.duckdns.org

# VPS 信息（部署用）
VPS_HOST=你的服务器IP
VPS_USER=ubuntu
